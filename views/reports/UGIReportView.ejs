<!DOCTYPE html>
<html>
<head>
    <title>유기산 리포트 뷰어 <%= username %></title>
    <link href="/css/report/UGIReport.css" rel="stylesheet">
    <link href="/css/report/UGIReport-print.css" rel="stylesheet">
    <link href="/css/font.css" rel="stylesheet">
    <link href="/css/xeicon.min.css" rel="stylesheet">
    <style>
        @media print {
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
        }
    </style>
</head>
<body>
    <!-- username을 hidden input으로 저장 -->
    <input type="hidden" id="hiddenUsername" value="<%= username %>">
    <!-- 인쇄 버튼 (인쇄 시에는 보이지 않음) -->
    <div class="no-print">
        <div class="header-title">
            <img src="/images/logo/biocom_logo.png">
        </div>
        <div class="header-btn">
            <span class="print">😊전체 프린트🖨️</span>
            <span class="print-result">🧁결과지만 프린트🖨️</span>
            <span class="print-solution">🎀솔루션만 프린트🖨️</span>
            <!-- <span class="pdf-save">pdf 저장</span> -->
            <div style="display: grid; grid-gap: 0.5em; grid-template-rows: repeat(2, 1fr 2fr) ; color: #0cb6af;">
                <div style="font-weight: bold; margin-top: 0.5em;"><span style="border-top: 1px dotted #0cb6af; border-radius: 0; cursor:default">📌출력 방법</span></div>
                <div style="margin-bottom: 0.5em;">프린터 선택에서 <br>원하는 프린터를 <br>선택 후 인쇄하세요.</div>
                <div style="font-weight: bold; margin-top: 0.5em;"><span style="border-top: 1px dotted #0cb6af; border-radius: 0; cursor:default">📌pdf 저장방법</span></div>
                <div>프린터 선택에서 <br>"PDF로 저장"을 <br>선택 후 저장하세요.</div>
            </div>
        </div>
        <span class='back' style="align-self: end;">뒤로가기</span>
        <span style="align-self: end;">by.연구개발팀</span>
    </div>
    <div class="report-area">
        <div class="title-page result">
            <div class="title-area">
                <div class="title-header s-core5">
                    <div class="report-name"><%= username %> 님</div>
                </div>
                <div class="title-content spoqa">
                    <span class="user-gender"><span>sample</span></span>
                    <span class="user-birth"><span>sample</span></span>
                    <span class="user-pk"><span>sample</span></span>
                    <span class="user-dt"><span>sample</span></span>
                    <span class="user-report-dt"><span>1234123499</span></span>
                </div>
            </div>
        </div>
        <div class="page hide">
            <div class="page-area"></div>
        </div>
    </div>

    <script src="/js/Common.js"></script>
    <script src="/js/lib/html2canvas.min.js"></script>
    <script src="/js/lib/jspdf.min.js"></script>
    <script src="/js/lib/bluebird.min.js"></script>
    <script src="/js/lib/echarts.min.js"></script>
    <script src="/js/report/UGIReport.js?V=2415"></script>
</body>
</html>
